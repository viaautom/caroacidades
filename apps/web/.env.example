# Supabase (Auth + Storage) — projeto self-hosted no Dokploy
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=troque-pela-anon-key-do-projeto
VITE_SUPABASE_STORAGE_BUCKET=sigweb

# URL do servidor pg_tileserv (serviço no Dokploy em produção, local em dev)
VITE_PG_TILESERV_URL=http://localhost:7800

# URL do Potree Viewer hospedado no Storage
VITE_POTREE_URL=

# URL do orto-mosaico WMTS (Storage/CDN)
VITE_ORTOMOSAICO_WMTS_URL=

# Token de acesso à API do Mapillary (street-level imagery)
# Criar em: https://www.mapillary.com/developer/api-documentation/
VITE_MAPILLARY_TOKEN=

# Senha de acesso ao painel de desenvolvedor na Gestão do SIG
VITE_DEV_PASSWORD=
