NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# PostgreSQL (Postgres do Supabase self-hosted em produção, local em dev)
DATABASE_URL=postgresql://sigweb:password@localhost:5432/sigweb
# "true" apenas se o Postgres exigir SSL (não é o caso do Supabase self-hosted padrão)
DATABASE_SSL=false

# Supabase (Auth + Storage) — chaves do projeto Supabase self-hosted no Dokploy
SUPABASE_URL=http://localhost:8000
SUPABASE_SERVICE_ROLE_KEY=troque-pela-service-role-key-do-projeto
SUPABASE_JWT_SECRET=troque-pelo-jwt-secret-do-projeto
SUPABASE_STORAGE_BUCKET=sigweb

# CORS
CORS_ORIGIN=http://localhost:5173,https://sigweb.tupancireta.rs.gov.br

# Cadastro Social — chave simétrica (pgcrypto pgp_sym_*) para criptografar CPF/NIS/PIS (req 88)
SOCIAL_ENC_KEY=troque-esta-chave-em-producao

# Senha de confirmação para "Apagar banco de dados" (Painel Dev → Gestão do SIG).
# Validada apenas no backend; a rota é bloqueada quando NODE_ENV=production.
DEV_WIPE_PASSWORD=
